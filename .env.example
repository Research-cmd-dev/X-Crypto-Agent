# ─────────────────────────────────────────────────────────────────────────────
# crypto-scout-swarm — environment variables
# Copy to `.env.local` (Next.js) / `.env` (scripts & Trigger.dev) and fill in.
# ─────────────────────────────────────────────────────────────────────────────

# xAI Grok (REQUIRED) — powers every agent (research + structured synthesis).
# Get key at https://console.x.ai/
XAI_API_KEY=xai-xxxxxxxx
# Code default is grok-3 (cost-effective). Override for higher quality if needed.
GROK_MODEL=grok-3

# X / Twitter API v2 (REQUIRED) — discovery + raw profile/follower data.
# Needs a paid X API plan with a Bearer token.
X_API_BEARER_TOKEN=

# GitHub (OPTIONAL but recommended) — raises rate limits + private signal.
# A classic or fine-grained PAT with public_repo read scope.
GITHUB_TOKEN=

# Price data (RECOMMENDED) — Birdeye (Solana) resolves early/pump.fun tokens by
# contract address. CoinGecko is intentionally not used (too late for discovery).
# Without a key the price agent falls back to the free DexScreener-by-address API.
BIRDEYE_API_KEY=

# Solana Tracker (RECOMMENDED) — primary source for pump.fun graduations,
# holders, and token metadata. Used by `npm run migrations`, migration Trigger
# job, and the on-chain agent. https://docs.solanatracker.io/
SOLANATRACKER_API_KEY=

# Bitquery (OPTIONAL / legacy) — Solana EAP GraphQL for 24h traders/trades when
# ST does not provide them. Fallback for migrations if SOLANATRACKER is unset.
BITQUERY_API_KEY=

# GMGN (OPTIONAL) — smart money / risk enrichment for launchScore + onchain agent.
# Launch ranking works without this (Solana Tracker + price are primary).
# Per https://docs.gmgn.ai/index/gmgn-agent-api if you want it:
# 1. Generate key pair locally; upload public key at https://gmgn.ai/ai
# 2. CLI: npx skills add GMGNAI/gmgn-skills
# Alternative security sources can plug into LaunchFeatures the same way.
GMGN_API_KEY=
GMGN_PRIVATE_KEY=
GMGN_COOKIE=

# Supabase (REQUIRED) — server-side (service role) used by jobs & API routes.
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (REQUIRED) — browser-side (anon) used by client components.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Trigger.dev (REQUIRED to run jobs) — from the Trigger.dev dashboard.
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_REF=proj_xxxxxxxx
