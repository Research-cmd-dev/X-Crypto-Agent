# ─────────────────────────────────────────────────────────────────────────────
# crypto-scout-swarm — environment variables
# Copy to `.env.local` (Next.js) / `.env` (scripts & Trigger.dev) and fill in.
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic (REQUIRED) — powers every agent.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# Override the default model if needed. Default: claude-opus-4-8
CLAUDE_MODEL=claude-opus-4-8

# X / Twitter API v2 (REQUIRED) — discovery + raw profile/follower data.
# Needs a paid X API plan with a Bearer token.
X_API_BEARER_TOKEN=

# GitHub (OPTIONAL but recommended) — raises rate limits + private signal.
# A classic or fine-grained PAT with public_repo read scope.
GITHUB_TOKEN=

# Price data (OPTIONAL) — CoinGecko Pro key improves reliability/limits.
# Without it the price agent falls back to the free CoinGecko + DexScreener endpoints.
COINGECKO_API_KEY=

# ── Solana on-chain data (memecoin funnel) ──────────────────────────────────
# GMGN (RECOMMENDED) — migration feed, token security/holders/smart-money, and the
# live on-chain scoring layer + outcome maturation. Without it these fall back to a
# mock (no real on-chain signal). Key from https://gmgn.ai/ai (Ed25519 public key).
GMGN_API_KEY=

# Birdeye (RECOMMENDED for history) — hourly historical price+volume for Solana
# mints (token_price_history backfill + the Solana historical backtest).
# Free tier available at https://birdeye.so (Data Services).
BIRDEYE_API_KEY=

# Bitquery (OPTIONAL) — fallback for historical price+volume on obscure/older tokens
# Birdeye doesn't cover. GraphQL API key from https://bitquery.io.
BITQUERY_API_KEY=

# Supabase (REQUIRED) — server-side (service role) used by jobs & API routes.
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (REQUIRED) — browser-side (anon) used by client components.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Trigger.dev (REQUIRED to run jobs) — from the Trigger.dev dashboard.
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_REF=proj_xxxxxxxx
